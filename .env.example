# Wheel credentials — copy to .env and fill in your values.
# Injected as compiler flags by load_env.py at build time.
# Get keys by scanning the QR sticker on each wheel hub:
#   python m25_qr_to_key.py "YOURQRSTRING"

M25_LEFT_MAC=28:05:a5:xx:xx:xx
M25_LEFT_KEY=000000000000000000000000000000000

M25_RIGHT_MAC=28:05:a5:xx:xx:xx
M25_RIGHT_KEY=0000000000000000000000000000000000
